        result = format_member_lookup({
            "display_name": "Nox",
            "username": "nox",
            "is_bot": False,
            "joined": "March 03, 2023",
            "created": "June 06, 2019",
            "roles": "Owner, Admin",
        })
        self.assertIn("Nox", result)
        self.assertIn("March 03, 2023", result)
        self.assertIn("Owner, Admin", result)

    def test_notes_appended_when_present(self):
